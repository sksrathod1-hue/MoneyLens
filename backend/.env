# Flask configuration
SECRET_KEY=super-secret-key-change-this-in-production
DEBUG=True
PORT=5000

# Database URL
# For SQLite, it defaults to standard sqlite:///backend/moneylens.db if not defined
DATABASE_URL=sqlite:///moneylens.db

# JWT settings
JWT_SECRET_KEY=another-super-secret-key-for-jwt
JWT_EXPIRY_HOURS=24

# SMS Gateway API Authentication
SMS_GATEWAY_API_KEY=local-dev-sms-gateway-key-100200

# AI/LLM API configuration
AI_API_KEY=your-gemini-api-key-here
AI_MODEL_NAME=gemini-1.5-flash
